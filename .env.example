# ML Prediction API — Environment Variables
# Copy this to .env and fill in values before running

APP_NAME=ML Prediction API
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Path to directory containing .joblib model files
MODELS_DIR=models

# CORS — comma-separated list of allowed origins
# In production: ALLOWED_ORIGINS=["https://yourdomain.ug","https://app.yourdomain.ug"]
ALLOWED_ORIGINS=["*"]

# Optional API key for protecting write endpoints (leave blank to disable)
API_KEY=
